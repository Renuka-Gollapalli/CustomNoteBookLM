# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Environments and Secrets
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Project-specific dynamic/local data folders (ignored but directory structure preserved via .gitkeep)
/uploads/*
!/uploads/.gitkeep

/vector_store/*
!/vector_store/.gitkeep

/outputs/*
!/outputs/.gitkeep

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
